# Optional: the server uses the current ClearCut n8n webhook when this is omitted.
N8N_BACKGROUND_REMOVAL_WEBHOOK_URL=https://your-n8n.example/webhook/remove-background

# Optional: set the same value in n8n and validate the X-ClearCut-Webhook-Secret header.
N8N_WEBHOOK_SECRET=

# Comma-separated HTTPS hosts that n8n may return in imageUrl.
PROCESSED_IMAGE_HOSTS=res.cloudinary.com

# Public address used by the contact page's mailto form.
VITE_CONTACT_EMAIL=you@example.com
